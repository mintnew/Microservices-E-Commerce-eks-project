pipeline {
    agent any

    environment {
        // Use Jenkins credentials IDs for SP secrets
        ARM_CLIENT_ID       = credentials('jenkins-arm-client-id')
        ARM_CLIENT_SECRET   = credentials('jenkins-arm-client-secret')
        ARM_SUBSCRIPTION_ID = credentials('jenkins-arm-subscription-id')
        ARM_TENANT_ID       = credentials('jenkins-arm-tenant-id')
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['apply', 'destroy'],
            description: '🔧 Select the Terraform action to perform'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo '✅ Checked out Git repository'
            }
        }

        stage('Terraform Version') {
            steps {
                sh 'terraform --version'
            }
        }

        stage('Terraform Init') {
            steps {
                dir('aks-terraform') {
                    sh 'terraform init --reconfigure'
                }
            }
        }

        stage('Terraform Validate') {
            steps {
                dir('aks-terraform') {
                    sh 'terraform validate -no-color'
                }
            }
        }

        stage('Terraform Plan') {
            steps {
                dir('aks-terraform') {
                    sh 'terraform plan -out=tfplan'
                }
            }
        }

        stage('Terraform Apply') {
            when {
                expression { params.ACTION == 'apply' }
            }
            steps {
                dir('aks-terraform') {
                    sh 'terraform apply -auto-approve tfplan'
                }
            }
        }

        stage('Terraform Destroy') {
            when {
                expression { params.ACTION == 'destroy' }
            }
            steps {
                dir('aks-terraform') {
                    sh 'terraform destroy -auto-approve'
                }
            }
        }
    }

    post {
        always {
            echo 'Pipeline finished ✅'
        }
        failure {
            echo 'Pipeline failed ❌'
        }
    }
}