pipeline {
    agent any 

    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }

        stage('Checkout from Git') {
            steps {
                git branch: 'master', url: 'https://github.com/mintnew/Microservices-E-Commerce-eks-project.git'
            }
        }

        stage("Docker Image Build") {
            steps {
                script {
                    dir('src/emailservice') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        sh 'docker build -t emailservice .'
                    }
                }
            }
        }

        stage("ACR Image Pushing") {
            environment {
                ACR_NAME = "acremailservice"               // Replace with your ACR name
                ACR_LOGIN_SERVER = "acremailservice.azurecr.io"
                AZURE_CLIENT_ID = "bc4df575-ddea-4750-bbbb-63b857353d58"
                AZURE_CLIENT_SECRET = "Wt28Q~qBEe_MMrpOSHfSt_C3gbJ1sHfGEQztuc2p"
                AZURE_TENANT_ID = "9fdb0924-bc9c-480d-a5fe-7f537262abc7"

                
            }
            steps {
                script {
                    sh '''
                    # Login to Azure using a service principal (use Jenkins credentials for SP)
                    az login --service-principal -u $AZURE_CLIENT_ID -p $AZURE_CLIENT_SECRET --tenant $AZURE_TENANT_ID

                    # Login Docker to ACR
                    az acr login --name $ACR_NAME

                    # Tag your Docker image for ACR
                    docker tag emailservice:latest $ACR_LOGIN_SERVER/emailservice:${BUILD_NUMBER}

                    # Push the image to ACR
                    docker push $ACR_LOGIN_SERVER/emailservice:${BUILD_NUMBER}
                    '''
                }
            }
        }

        stage('Update Deployment file') {
            environment {
                GIT_REPO_NAME = "Microservices-E-Commerce-eks-project"
                GIT_EMAIL = "chanchlesh2597@gmail.com"
                GIT_USER_NAME = "mintnew"
                IMAGE_NAME = "emailservice"
                REPO_URL = "acremailservice.azurecr.io/emailservice"  // ACR repository URL
                YAML_FILE = "emailservice.yaml"
            }
            steps {
                dir('kubernetes-files') {
                    withCredentials([string(credentialsId: 'my-git-pattoken', variable: 'git_token')]) { {
                        sh '''
                            git config user.email "${GIT_EMAIL}"
                            git config user.name "${GIT_USER_NAME}"
                            BUILD_NUMBER=${BUILD_NUMBER}

                            # Update image in YAML and push to GitHub
                            sed -i "s#image:.*#image: ${REPO_URL}:$BUILD_NUMBER#g" ${YAML_FILE}
                            git add .
                            git commit -m "Update ${IMAGE_NAME} Image to version \${BUILD_NUMBER}"
                            git push https://${git_token}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME}.git HEAD:master
                        '''
                    }
                }
            }
        }
    }
    }
